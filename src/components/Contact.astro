---
import { site } from "@/content/site"
import GitHubIcon from "@/components/icons/GitHub.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div
  class="relative min-w-0 overflow-hidden rounded-2xl border border-gray-200/90 bg-gradient-to-br from-white/90 via-gray-50/80 to-amber-50/40 p-5 shadow-sm dark:border-white/10 dark:from-gray-950/80 dark:via-gray-950/60 dark:to-amber-950/20 sm:p-8 md:p-10"
>
  <div
    class="pointer-events-none absolute -right-16 -top-16 size-56 rounded-full bg-yellow-400/15 blur-3xl dark:bg-yellow-400/10"
    aria-hidden="true"
  >
  </div>
  <div class="relative max-w-2xl">
    <p class="text-sm font-semibold uppercase tracking-wider text-amber-700/90 dark:text-amber-300/90">
      Contacto
    </p>
    <h3 class="mt-2 break-words text-xl font-bold tracking-tight text-gray-900 sm:text-2xl dark:text-white">
      {site.contact.title}
    </h3>
    <p class="mt-4 text-pretty text-base leading-relaxed text-gray-700 sm:text-lg dark:text-gray-300">
      {site.contact.lead}
    </p>
    <nav
      class="mt-8 flex flex-wrap gap-3"
      aria-label="Enlaces de contacto"
    >
      <SocialPill
        href={`mailto:${site.links.email}`}
        aria-label={`Enviar correo a ${site.links.email}`}
      >
        <MailIcon class="size-4 shrink-0" aria-hidden="true" />
        Escríbeme
      </SocialPill>
      <SocialPill href={site.links.linkedin}>
        <LinkedInIcon class="size-4 shrink-0" />
        LinkedIn
      </SocialPill>
      <SocialPill href={site.links.github}>
        <GitHubIcon class="size-4 shrink-0" />
        GitHub
      </SocialPill>
      {
        site.links.cv && (
          <SocialPill href={site.links.cv}>
            <span class="text-sm font-medium">Descargar CV</span>
          </SocialPill>
        )
      }
    </nav>
  </div>
</div>
