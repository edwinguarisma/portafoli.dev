---
import LinkInline from "./LinkInline.astro"
import ArrowRight from "./icons/ArrowRight.astro"

interface Props {
  title: string
  company: string
  description: string
  link?: string
  date: string
  current?: boolean
}

const { title, company, description, link, date, current = false } = Astro.props
---

<div
  class:list={[
    "experience-item relative mx-0 grid grid-cols-1 gap-6 pb-12 sm:mx-2 md:mx-8 md:grid-cols-5 md:gap-10 lg:mx-12",
    "border-l-2 border-black/20 pl-6 dark:border-white/15",
    "md:border-l-0 md:pl-0",
    "md:before:absolute md:before:left-[-35px] md:before:top-0 md:before:z-0 md:before:block md:before:h-full",
    "md:before:border-l-2 md:before:border-black/20 md:before:content-[''] dark:md:before:border-white/15",
  ]}
>
  <div class="relative pb-2 md:col-span-2 md:pb-12">
    <div class="sticky top-24 md:top-0">
      <div class="flex items-start gap-2">
        <span
          class="absolute -left-[31px] top-1.5 flex size-[14px] items-center justify-center sm:-left-[33px] md:-left-[42px]"
          aria-hidden="true"
        >
          {current && (
            <span class="animate-ping motion-reduce:animate-none absolute inline-flex size-full rounded-full bg-yellow-400/40"></span>
          )}
          <span
            class={`relative inline-flex size-[10px] rounded-full bg-yellow-400 ${current ? "shadow-[0_0_8px_2px_rgba(251,191,36,0.45)]" : ""}`}
          ></span>
        </span>
        <div class="min-w-0 flex-1">
          <h3 class="text-lg font-bold leading-snug text-yellow-400 sm:text-xl">
            {title}
          </h3>
          <h4 class="mt-1 text-base font-semibold leading-snug text-gray-600 dark:text-white sm:text-lg">
            {company}
          </h4>
          <time class="m-0 mt-1 block p-0 text-sm text-gray-600/80 dark:text-white/80"
            >{date}</time
          >
        </div>
      </div>
    </div>
  </div>
  <div
    class="relative flex min-w-0 flex-col gap-2 pb-4 text-gray-600 dark:text-gray-300 md:col-span-3"
  >
    <p class="text-pretty leading-relaxed">{description}</p>
    {
      link && (
        <LinkInline href={link}>
          Saber más sobre {company}{" "}
          <ArrowRight class="size-5 shrink-0" aria-hidden="true" />
        </LinkInline>
      )
    }
  </div>
</div>
