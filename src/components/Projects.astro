---
import GitHub from "./icons/GitHub.astro"
import ExternalLink from "./icons/ExternalLink.astro"
import LinkButton from "./LinkButton.astro"
import projectsData from "@/data/projects.json"

type Tag = {
  name: string
  /** Slug de simple-icons.org (logo oficial). Opcional si la etiqueta es conceptual. */
  slug?: string
  /** Clases para la píldora (color marca). */
  class: string
}

const TAGS: Record<string, Tag> = {
  NEXT: {
    name: "Next.js",
    slug: "nextdotjs",
    class: "bg-black text-white",
  },
  REACT: {
    name: "React",
    slug: "react",
    class: "bg-[#20232a] text-white",
  },
  EXPO: {
    name: "Expo",
    slug: "expo",
    class: "bg-black text-white",
  },
  NODE: {
    name: "Node.js",
    slug: "nodedotjs",
    class: "bg-[#026E00] text-white",
  },
  TS: {
    name: "TypeScript",
    slug: "typescript",
    class: "bg-[#3178C6] text-white",
  },
  POSTGRES: {
    name: "PostgreSQL",
    slug: "postgresql",
    class: "bg-[#336791] text-white",
  },
  TAILWIND: {
    name: "Tailwind CSS",
    slug: "tailwindcss",
    class: "bg-[#0C4A6E] text-white",
  },
  ASTRO: {
    name: "Astro",
    slug: "astro",
    class: "bg-[#13141C] text-white",
  },
  SEQUELIZE: {
    name: "Sequelize",
    slug: "sequelize",
    class: "bg-[#03AFC7] text-white",
  },
  DOCKER: {
    name: "Docker",
    slug: "docker",
    class: "bg-[#2496ED] text-white",
  },
  SMS: {
    name: "Mensajería SMS",
    class: "bg-rose-700 text-white",
  },
  ECOMMERCE: {
    name: "E-commerce",
    class: "bg-amber-500 text-black",
  },
  DASHBOARD: {
    name: "Dashboard",
    class: "bg-indigo-700 text-white",
  },
  MOBILE: {
    name: "App Móvil",
    class: "bg-emerald-700 text-white",
  },
  CATALOG: {
    name: "Catálogo",
    class: "bg-fuchsia-700 text-white",
  },
}

type ProjectInput = {
  title: string
  description: string
  tags: string[]
  image?: string
  link?: string
  github?: string
  private?: boolean
}

const PROJECTS = (projectsData as ProjectInput[]).map((project) => ({
  ...project,
  resolvedTags: project.tags
    .map((key) => TAGS[key])
    .filter((tag): tag is Tag => Boolean(tag)),
}))
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(
      ({
        image,
        title,
        description,
        resolvedTags,
        link,
        github,
        private: isPrivate,
      }) => (
        <article class="group flex min-w-0 flex-col space-x-0 space-y-6 md:flex-row md:space-x-10 md:space-y-0">
          <div class="w-full min-w-0 md:w-1/2">
            <div class="relative flex aspect-[16/10] w-full flex-col items-center overflow-hidden rounded-xl shadow-xl transition-transform duration-500 ease-in-out sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-[0_20px_60px_-10px_rgba(251,191,36,0.2)] lg:border lg:border-gray-200/70 lg:dark:border-gray-800 lg:hover:border-yellow-400/30 lg:hover:bg-gray-800/50">
              {image ? (
                <img
                  alt={title}
                  class="h-full w-full object-cover object-top transition duration-500 md:scale-105 md:group-hover:scale-100"
                  loading="lazy"
                  decoding="async"
                  src={image}
                />
              ) : (
                <div
                  class="relative flex h-full w-full items-center justify-center bg-gradient-to-br from-amber-300/40 via-orange-400/25 to-gray-100 px-6 text-center dark:from-amber-500/25 dark:via-orange-600/15 dark:to-gray-900"
                  aria-hidden="true"
                >
                  <div
                    class="absolute inset-0 opacity-[0.06] dark:opacity-[0.08]"
                    style="background-image: url('/noise.svg'); background-size: 200px 200px;"
                  />
                  <span class="relative text-balance text-2xl font-bold leading-tight text-gray-800/80 dark:text-gray-100/80 sm:text-3xl">
                    {title}
                  </span>
                </div>
              )}
              <div
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                aria-hidden="true"
              />
            </div>
          </div>

          <div class="flex w-full min-w-0 flex-col justify-center md:w-1/2 md:max-w-lg">
            <h3 class="text-xl font-bold leading-snug text-gray-800 sm:text-2xl dark:text-gray-100">
              {title}
            </h3>
            <ul class="mt-3 flex flex-row flex-wrap gap-2" aria-label="Tecnologías y tipo de producto">
              {resolvedTags.map((tag) => (
                <li>
                  <span
                    class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-medium ${tag.class}`}
                  >
                    {tag.slug && (
                      <img
                        src={`https://cdn.simpleicons.org/${tag.slug}/FFFFFF`}
                        alt=""
                        width="14"
                        height="14"
                        loading="lazy"
                        decoding="async"
                        class="size-3.5 shrink-0"
                      />
                    )}
                    <span>{tag.name}</span>
                  </span>
                </li>
              ))}
            </ul>

            <p class="mt-3 text-pretty leading-relaxed text-gray-700 dark:text-gray-400">
              {description}
            </p>

            <footer class="mt-5 flex flex-wrap items-center gap-3">
              {github && (
                <LinkButton href={github}>
                  <GitHub class="size-5" />
                  Código
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <ExternalLink class="size-4" />
                  Ver demo
                </LinkButton>
              )}
              {!github && !link && isPrivate && (
                <span
                  class="inline-flex items-center gap-2 rounded-full border border-gray-200/90 bg-gray-50 px-3 py-1.5 text-xs font-medium text-gray-600 dark:border-white/10 dark:bg-gray-900/60 dark:text-gray-300"
                  title="Código propiedad del cliente"
                >
                  <span
                    class="inline-block size-1.5 rounded-full bg-yellow-400"
                    aria-hidden="true"
                  />
                  Proyecto privado — detalles bajo petición
                </span>
              )}
            </footer>
          </div>
        </article>
      ),
    )
  }
</div>
