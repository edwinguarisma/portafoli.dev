---
import { site } from "@/content/site"

type Item =
  | string
  | { name: string; slug?: string; invert?: boolean }

const toItem = (item: Item) =>
  typeof item === "string" ? { name: item } : item
---

<div
  class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
  role="list"
  aria-label="Stack técnico por categorías"
>
  {
    site.techStack.map((group) => (
      <article
        role="listitem"
        class="group min-w-0 rounded-2xl border border-gray-200/80 bg-white/60 p-4 shadow-sm backdrop-blur-sm transition duration-200 hover:-translate-y-0.5 hover:border-yellow-400/35 hover:shadow-[0_12px_40px_-12px_rgba(251,191,36,0.18)] dark:border-white/10 dark:bg-gray-950/45 dark:hover:border-yellow-400/25 sm:p-5"
      >
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
          {group.title}
        </h3>
        <ul class="mt-4 flex flex-wrap gap-2">
          {group.items.map((raw) => {
            const item = toItem(raw as Item)
            return (
              <li>
                <span class="inline-flex items-center gap-2 rounded-full border border-gray-200/90 bg-gray-50 px-3 py-1.5 text-sm font-medium text-gray-800 dark:border-white/10 dark:bg-gray-900/60 dark:text-gray-100">
                  {item.slug ? (
                    <img
                      src={`https://cdn.simpleicons.org/${item.slug}`}
                      alt=""
                      width="16"
                      height="16"
                      loading="lazy"
                      decoding="async"
                      class:list={[
                        "size-4 shrink-0",
                        item.invert && "dark:invert",
                      ]}
                    />
                  ) : (
                    <span
                      class="inline-block size-1.5 shrink-0 rounded-full bg-yellow-400/80"
                      aria-hidden="true"
                    />
                  )}
                  <span>{item.name}</span>
                </span>
              </li>
            )
          })}
        </ul>
      </article>
    ))
  }
</div>
