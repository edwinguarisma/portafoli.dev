---
type Props = {
  href: string
  class?: string
  target?: string
  rel?: string
  "aria-label"?: string
}

const { href, class: className, target: targetProp, rel: relProp, ...rest } =
  Astro.props as Props

const isExternal = /^https?:\/\//.test(href)
const target = targetProp ?? (isExternal ? "_blank" : undefined)
const rel = relProp ?? (isExternal ? "noopener noreferrer" : undefined)

const baseClass =
  "inline-flex min-h-11 min-w-[2.75rem] items-center justify-center gap-2 px-4 py-2.5 text-gray-800 transition bg-gray-100 border border-gray-300 rounded-full dark:bg-gray-800 dark:border-gray-600 dark:text-white focus-visible:ring-yellow-500/80 text-md hover:bg-gray-900 hover:border-gray-700 hover:text-white dark:hover:bg-gray-100 dark:hover:border-gray-300 dark:hover:text-black group max-w-fit focus:outline-none focus-visible:outline-none focus-visible:ring focus-visible:ring-white focus-visible:ring-offset-2 active:scale-[0.98] active:bg-black touch-manipulation"
---

<a
  href={href}
  class:list={[baseClass, className]}
  target={target}
  rel={rel}
  {...rest}
>
  <slot />
</a>
