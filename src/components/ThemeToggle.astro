---
import SunIcon from "./icons/Sun.astro"
import MoonIcon from "./icons/Moon.astro"
---

<button
  id="theme-toggle-btn"
  type="button"
  class="inline-flex size-10 shrink-0 cursor-pointer appearance-none items-center justify-center rounded-full border-none text-gray-600 transition-colors duration-200 hover:bg-yellow-400/15 hover:text-yellow-500 dark:text-gray-300 dark:hover:text-yellow-400 sm:size-11"
  aria-label="Cambiar tema"
>
  <SunIcon  class="theme-toggle-icon size-5 transition-all duration-300" id="light" />
  <MoonIcon class="theme-toggle-icon absolute size-5 transition-all duration-300" id="dark" />
</button>

<script is:inline>
  ;(function () {
    const STORAGE_KEY = "theme"

    function getIsDark() {
      const stored = localStorage.getItem(STORAGE_KEY)
      if (stored === "dark") return true
      if (stored === "light") return false
      return window.matchMedia("(prefers-color-scheme: dark)").matches
    }

    function applyTheme() {
      const isDark = getIsDark()
      document.documentElement.classList.toggle("dark", isDark)
      document.querySelectorAll(".theme-toggle-icon").forEach(function (el) {
        el.style.scale = el.id === (isDark ? "dark" : "light") ? "1" : "0"
      })
    }

    function toggle() {
      const nowDark = document.documentElement.classList.contains("dark")
      localStorage.setItem(STORAGE_KEY, nowDark ? "light" : "dark")
      applyTheme()
    }

    applyTheme()

    window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", applyTheme)

    function attachClick() {
      var btn = document.getElementById("theme-toggle-btn")
      if (btn) {
        btn.removeEventListener("click", toggle)
        btn.addEventListener("click", toggle)
      }
    }

    attachClick()

    document.addEventListener("astro:after-swap", function () {
      applyTheme()
      attachClick()
    })
  })()
</script>
