---
const { className } = Astro.props
---

<div class="mb-8">
  <h2
    class={`flex min-w-0 flex-wrap items-center gap-x-3 gap-y-2 text-2xl font-bold tracking-tight text-black/80 min-[400px]:text-3xl dark:text-white ${className ?? ""}`}
  >
    <slot />
  </h2>
  <!-- Gradient accent underline -->
  <div
    class="mt-3 h-px w-20 bg-gradient-to-r from-yellow-400/70 to-transparent"
    aria-hidden="true"
  >
  </div>
</div>
